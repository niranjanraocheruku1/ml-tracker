{
  "name": "ml-tracker",
  "version": "1.0.0",
  "description": "Daily Execution Tracker for ML Engineers",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.mltracker.app",
    "productName": "ML Tracker",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "files": [
      "index.html",
      "main.js"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
